# Amazon Cognito Configuration Example
# Add these configuration values to your environment or config file

# Required Cognito Settings
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-app-client-id
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:5656/auth/callback

# Optional Cognito Settings
COGNITO_IDENTITY_POOL_ID=us-east-1:12345678-1234-1234-1234-123456789012
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Example Environment Variables for Production
# export COGNITO_REGION="us-east-1"
# export COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
# export COGNITO_CLIENT_ID="your-cognito-app-client-id"
# export COGNITO_CLIENT_SECRET="your-cognito-app-client-secret"
# export COGNITO_DOMAIN="https://your-domain.auth.us-east-1.amazoncognito.com"
# export COGNITO_REDIRECT_URI="http://localhost:5656/auth/callback"

# PowerShell Environment Variables (Windows)
# $env:COGNITO_REGION="us-east-1"
# $env:COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
# $env:COGNITO_CLIENT_ID="your-cognito-app-client-id"
# $env:COGNITO_CLIENT_SECRET="your-cognito-app-client-secret"
# $env:COGNITO_DOMAIN="https://auth.oudirect-st.ou.org"
# $env:COGNITO_REDIRECT_URI="http://localhost:5656/auth/callback"